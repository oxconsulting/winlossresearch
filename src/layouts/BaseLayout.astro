---
/**
 * src/layouts/BaseLayout.astro
 *
 * CHANGES FROM PRIOR VERSION:
 * 1. Imports buildPageGraph from utils/schema — pass graph prop to <Seo>
 * 2. Adds <link rel="sitemap"> and <link rel="alternate" rss> to extraLinks
 * 3. Fixes title template so homepage doesn't double site name
 * 4. Adds <ClientRouter> for viewport prefetch
 * 5. Suppresses redundant Twitter tags (OG fallback handles it)
 * 6. ogType defaults to 'article' for content pages; callers can override
 * 7. 'article' pageGraphType branch no longer requires publishDate to fire —
 *    pillar pages have no publishDate field (evergreen content, by design)
 *    and were previously falling through to the generic 'list' graph.
 *
 * USAGE EXAMPLE (pillar page):
 *   <BaseLayout
 *     title="Why Internal Win/Loss Data Fails"
 *     description="CRM notes, rep debriefs..."
 *     canonicalUrl={Astro.url.href}
 *     ogType="article"
 *     breadcrumbs={[{ name: 'Topics', url: 'https://winlossresearch.com/topics/' }, { name: 'Why Internal Win/Loss Data Fails', url: 'https://winlossresearch.com/topics/why-internal-win-loss-data-fails/' }]}
 *     pageGraphType="article"
 *   >
 *     <slot />
 *   </BaseLayout>
 */
import Seo from '@jdevalk/astro-seo-graph/Seo.astro';
import { ClientRouter } from 'astro:transitions';
import { buildPageGraph, SITE_URL, SITE_NAME, type PageGraphOptions } from '../utils/schema';
import '../styles/global.css';

interface Props {
  title: string;
  description: string;
  canonicalUrl?: string;
  /**
   * Open Graph type. Defaults to 'website' for index/list pages; pass 'article'
   * for pillar pages, Perspectives posts, FAQ pages, and glossary pages.
   */
  ogType?: 'website' | 'article';
  /**
   * OG image URL. Defaults to the static fallback.
   * Pass a full absolute URL when a per-page OG image exists.
   */
  ogImageUrl?: string;
  /** Optional. Required for Perspectives posts; pillar pages have none. */
  publishDate?: Date;
  modifiedDate?: Date;
  /** Breadcrumb trail, excluding the root. e.g. [{ name: 'FAQ', url: 'https://winlossresearch.com/faq/' }, { name: 'What is...', url: 'https://winlossresearch.com/faq/what-is-.../' }] */
  breadcrumbs?: Array<{ name: string; url: string }>;
  /**
   * Which graph type to build. Matches PageGraphOptions['pageType'].
   * Defaults to 'home' for the homepage, 'list' for index pages.
   */
  pageGraphType?: PageGraphOptions['pageType'];
  /** FAQ-specific: the full question text */
  faqQuestion?: string;
  /** FAQ-specific: the plain-text answer (first paragraph is fine) */
  faqAnswer?: string;
  /** Glossary-specific: the term name */
  termName?: string;
  /** Glossary-specific: the term definition */
  termDefinition?: string;
  noindex?: boolean;
}

const {
  title,
  description,
  canonicalUrl = Astro.url.href,
  ogType = 'website',
  ogImageUrl = `${SITE_URL}/og/default.jpg`,
  publishDate,
  modifiedDate,
  breadcrumbs,
  pageGraphType = 'list',
  faqQuestion,
  faqAnswer,
  termName,
  termDefinition,
  noindex = false,
} = Astro.props;

// Build the appropriate graph for this page type
let graphOptions: PageGraphOptions;

if (pageGraphType === 'faq' && faqQuestion && faqAnswer) {
  graphOptions = {
    pageType: 'faq',
    url: canonicalUrl,
    name: title,
    description,
    question: faqQuestion,
    answer: faqAnswer,
    breadcrumbs,
  };
} else if (pageGraphType === 'glossary' && termName && termDefinition) {
  graphOptions = {
    pageType: 'glossary',
    url: canonicalUrl,
    name: title,
    description,
    termName,
    termDefinition,
    breadcrumbs,
  };
} else if (pageGraphType === 'article') {
  // publishDate is optional here — pillar pages have none, Article schema
  // simply omits datePublished/dateModified when absent (see schema.ts)
  graphOptions = {
    pageType: 'article',
    url: canonicalUrl,
    name: title,
    description,
    publishDate,
    modifiedDate,
    breadcrumbs,
    imageUrl: ogImageUrl,
  };
} else if (pageGraphType === 'perspectives' && publishDate) {
  graphOptions = {
    pageType: 'perspectives',
    url: canonicalUrl,
    name: title,
    description,
    publishDate,
    modifiedDate,
    breadcrumbs,
    imageUrl: ogImageUrl,
  };
} else {
  graphOptions = {
    pageType: pageGraphType as 'home' | 'list',
    url: canonicalUrl,
    name: title,
    description,
  };
}

const graph = buildPageGraph(graphOptions);

// For Perspectives posts and dated Article pages: build OG article metadata.
// Pillar pages (no publishDate) simply get no article:published_time tag —
// ogType can still be 'article' without it.
const articleMeta =
  (pageGraphType === 'perspectives' || pageGraphType === 'article') && publishDate
    ? {
        publishedTime: publishDate,
        modifiedTime: modifiedDate ?? publishDate,
        authors: [`${SITE_URL}/about/`],
        section: 'Win/Loss Research',
      }
    : undefined;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <Seo
      title={title}
      titleTemplate={`%s | ${SITE_NAME}`}
      description={description}
      canonical={canonicalUrl}
      ogType={ogType}
      ogImage={ogImageUrl}
      ogImageAlt={`${title} — Win/Loss Research`}
      ogImageWidth={1200}
      ogImageHeight={675}
      siteName={SITE_NAME}
      locale="en_US"
      noindex={noindex}
      article={articleMeta}
      graph={graph}
      extraLinks={[
        { rel: 'icon', type: 'image/svg+xml', href: '/favicon.svg' },
        { rel: 'sitemap', href: '/sitemap-index.xml' },
        { rel: 'alternate', type: 'application/rss+xml', href: '/feed.xml', title: `${SITE_NAME} — Perspectives` },
      ]}
    />
    <ClientRouter defaultStrategy="viewport" />
  </head>
  <body>
    <header>
      <nav>
        <a href="/">Win/Loss Research</a>
        <a href="/topics/">Topics</a>
        <a href="/perspectives/">Perspectives</a>
        <a href="/faq/">FAQ</a>
        <a href="/glossary/">Glossary</a>
        <a href="/playbook/">Playbook</a>
        <a href="/about/">About</a>
      </nav>
    </header>

    <main>
      <slot />
    </main>

    <footer>
      <!-- Footer content -->
    </footer>
  </body>
</html>
