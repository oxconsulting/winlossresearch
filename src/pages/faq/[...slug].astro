---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { breadcrumbsFromUrl } from '@jdevalk/astro-seo-graph';
import {
  makeIds,
  buildWebSite,
  buildWebPage,
  buildPiece,
  buildBreadcrumbList,
  assembleGraph,
} from '@jdevalk/seo-graph-core';
import type { FAQPage, Person, Question } from 'schema-dts';

export async function getStaticPaths() {
  const entries = await getCollection('faq');
  return entries.map((entry) => ({
    params: { slug: entry.id },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);

const siteUrl = 'https://winlossresearch.com';
const siteName = 'Win/Loss Research';
const canonicalUrl = Astro.url.href;

const ids = makeIds({
  siteUrl,
  personUrl: `${siteUrl}/about/`,
});

const person = buildPiece<Person>({
  '@type': 'Person',
  '@id': ids.person,
  name: 'Daniel Oxenburgh',
  url: `${siteUrl}/about/`,
  jobTitle: 'Founder',
  worksFor: {
    '@type': 'Organization',
    name: 'Ox Win/Loss',
    url: 'https://oxrevs.com',
  },
  sameAs: [
    'https://www.linkedin.com/in/danieloxenburgh/',
    'https://oxrevs.com',
  ],
});

const website = buildWebSite(
  {
    url: `${siteUrl}/`,
    name: siteName,
    description:
      'Independent research and analysis on win/loss methodology for B2B SaaS companies.',
    publisher: { '@id': ids.person },
    inLanguage: 'en-US',
  },
  ids,
);

const webPage = buildWebPage(
  {
    url: canonicalUrl,
    name: entry.data.title,
    isPartOf: { '@id': ids.website },
    inLanguage: 'en-US',
    datePublished: entry.data.publishDate,
    dateModified: entry.data.updatedDate ?? entry.data.publishDate,
  },
  ids,
  'WebPage',
);

// FAQPage schema — primary AEO signal for this content type
// acceptedAnswer.text is what AI systems extract for direct answers
const faqPage = buildPiece<FAQPage>({
  '@type': 'FAQPage',
  '@id': `${canonicalUrl}#faqpage`,
  mainEntity: [
    {
      '@type': 'Question',
      name: entry.data.title,
      acceptedAnswer: {
        '@type': 'Answer',
        text: entry.data.description,
      },
    } as Question,
  ],
});

const breadcrumbItems = breadcrumbsFromUrl({
  url: Astro.url,
  siteUrl,
  labels: { faq: 'FAQ' },
});
const breadcrumb = buildBreadcrumbList({ url: canonicalUrl, items: breadcrumbItems }, ids);

const graph = assembleGraph([person, website, webPage, faqPage, breadcrumb]);
---

<BaseLayout
  title={entry.data.title}
  description={entry.data.description}
  canonicalUrl={canonicalUrl}
  publishDate={entry.data.publishDate}
  updatedDate={entry.data.updatedDate}
  graph={graph}
>
  <article class="faq-page">
    <Content />
  </article>
</BaseLayout>
