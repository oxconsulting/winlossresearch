---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import {
  makeIds,
  buildWebSite,
  buildWebPage,
  buildArticle,
  buildPiece,
  buildBreadcrumbList,
  assembleGraph,
} from '@jdevalk/seo-graph-core';
import type { Person } from 'schema-dts';

export async function getStaticPaths() {
  const entries = await getCollection('perspectives');
  return entries.map((entry) => ({
    params: { slug: entry.id },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);

const siteUrl = 'https://winlossresearch.com';
const siteName = 'Win/Loss Research';
const canonicalUrl = Astro.url.href;

const ids = makeIds({
  siteUrl,
  personUrl: `${siteUrl}/about/`,
});

// Person entity — used as author @id reference in BlogPosting
const person = buildPiece<Person>({
  '@type': 'Person',
  '@id': ids.person,
  name: 'Daniel Oxenburgh',
  url: `${siteUrl}/about/`,
  jobTitle: 'Founder',
  worksFor: {
    '@type': 'Organization',
    name: 'Ox Win/Loss',
    url: 'https://oxrevs.com',
  },
  sameAs: [
    'https://www.linkedin.com/in/danieloxenburgh/',
    'https://oxrevs.com',
  ],
});

const website = buildWebSite(
  {
    url: `${siteUrl}/`,
    name: siteName,
    description:
      'Independent research and analysis on win/loss methodology for B2B SaaS companies.',
    publisher: { '@id': ids.person },
    inLanguage: 'en-US',
  },
  ids,
);

const webPage = buildWebPage(
  {
    url: canonicalUrl,
    name: entry.data.title,
    isPartOf: { '@id': ids.website },
    inLanguage: 'en-US',
    datePublished: entry.data.publishDate,
    dateModified: entry.data.updatedDate ?? entry.data.publishDate,
  },
  ids,
  'WebPage',
);

// BlogPosting with explicit author @id — this is the E-E-A-T signal
const article = buildArticle(
  {
    headline: entry.data.title,
    description: entry.data.description,
    url: canonicalUrl,
    datePublished: entry.data.publishDate,
    dateModified: entry.data.updatedDate ?? entry.data.publishDate,
    isPartOf: { '@id': ids.webpage },
    author: { '@id': ids.person },
    publisher: { '@id': ids.person },
    inLanguage: 'en-US',
  },
  ids,
  'BlogPosting',
);

const breadcrumb = buildBreadcrumbList(
  [
    { name: 'Home', url: `${siteUrl}/` },
    { name: 'Perspectives', url: `${siteUrl}/perspectives/` },
    { name: entry.data.title, url: canonicalUrl },
  ],
  ids,
);

const graph = assembleGraph([person, website, webPage, article, breadcrumb]);
---

<BaseLayout
  title={entry.data.title}
  description={entry.data.description}
  canonicalUrl={canonicalUrl}
  ogType="article"
  publishDate={entry.data.publishDate}
  updatedDate={entry.data.updatedDate}
  graph={graph}
>
  <article class="perspectives-post">
    <header class="post-header">
      <p class="byline">
        By <a href="/about/">{entry.data.author}</a>,
        {entry.data.authorTitle} —
        <a href={entry.data.authorUrl} rel="noopener">Ox Win/Loss</a>
      </p>
    </header>
    <Content />
  </article>
</BaseLayout>
